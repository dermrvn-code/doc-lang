{
    "name": "doc-lang-cli",
    "description": "The cli specific package",
    "version": "0.0.1",
    "type": "module",
    "engines": {
        "node": ">=20.10.0",
        "npm": ">=10.2.3"
    },
    "files": [
        "bin",
        "out"
    ],
    "main": "./out/index.js",
    "types": "./out/index.d.ts",
    "exports": {
        ".": {
            "import": "./out/index.js",
            "types": "./out/index.d.ts"
        }
    },
    "bin": {
        "doc-lang": "./bin/cli.js"
    },
    "scripts": {
        "clean": "shx rm -fr *.tsbuildinfo out",
        "build": "tsc -p tsconfig.json",
        "build:clean": "npm run clean && npm run build",
        "test": "vitest run --reporter=verbose"
    },
    "dependencies": {
        "doc-lang-language": "0.0.1",
        "chalk": "~5.3.0",
        "commander": "~11.1.0"
    }
}
