{
    "name": "doc-lang-workspace",
    "description": "Base workspace package",
    "version": "0.0.1",
    "type": "module",
    "private": true,
    "scripts": {
        "clean": "npm run clean --workspaces",
        "watch": "tsc -b tsconfig.build.json --watch",
        "build": "tsc -b tsconfig.build.json && npm run build --workspaces",
        "build:clean": "npm run clean && npm run build",
        "langium:generate": "npm run --workspace packages/language langium:generate",
        "langium:watch": "npm run --workspace packages/language langium:watch",
        "dev": "npm run --workspace packages/web dev",
        "test": "npm run --workspace packages/language test"
    },
    "devDependencies": {
        "@codingame/esbuild-import-meta-url-plugin": "~1.0.3",
        "@codingame/monaco-vscode-rollup-vsix-plugin": "^23.0.0",
        "@types/node": "~20.17.48",
        "shx": "~0.4.0",
        "typescript": "~5.8.3"
    },
    "workspaces": [
        "packages/language",
        "packages/cli",
        "packages/extension",
        "packages/web"
    ],
    "dependencies": {
        "markdown-it": "^14.1.1",
        "markdown-it-attrs": "^4.5.0"
    }
}
